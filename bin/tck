#!/usr/bin/env bash
#
# Runs the A2A TCK (Technology Compatibility Kit) against a local server.
#
# Usage: bin/tck [mandatory|capabilities|quality|features|all]
#
# Prerequisites: uv or pip (Python package manager)

set -euo pipefail

CATEGORY="${1:-mandatory}"
PORT="${A2A_TCK_PORT:-9999}"
TCK_DIR=".tck"
SUT_URL="http://localhost:${PORT}"
SERVER_PID=""

cleanup() {
  if [ -n "$SERVER_PID" ] && kill -0 "$SERVER_PID" 2>/dev/null; then
    echo "Stopping server (PID $SERVER_PID)..."
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
  fi
}

trap cleanup EXIT

# --- Detect Python tooling ---

if command -v uv &> /dev/null; then
  USE_UV=true
else
  USE_UV=false
  echo "uv not found, falling back to pip"
fi

# --- Clone TCK if needed ---

if [ ! -d "$TCK_DIR" ]; then
  echo "Cloning A2A TCK..."
  git clone https://github.com/a2aproject/a2a-tck.git "$TCK_DIR"
else
  echo "TCK already cloned in $TCK_DIR"
fi

# --- Install Python deps ---

echo "Installing TCK dependencies..."
cd "$TCK_DIR"
if [ "$USE_UV" = true ]; then
  uv sync
else
  python3 -m venv .venv 2>/dev/null || true
  .venv/bin/pip install -e .
fi
cd ..

# --- Start Elixir server ---

echo "Starting TCK server on port $PORT..."
A2A_TCK_PORT="$PORT" mix run test/tck/server.exs &
SERVER_PID=$!

# Poll until agent card responds
echo "Waiting for server..."
for i in $(seq 1 30); do
  if curl -sf "${SUT_URL}/.well-known/agent-card.json" > /dev/null 2>&1; then
    echo "Server ready."
    break
  fi
  if ! kill -0 "$SERVER_PID" 2>/dev/null; then
    echo "ERROR: Server process died."
    exit 1
  fi
  sleep 1
done

# Verify server is actually responding
if ! curl -sf "${SUT_URL}/.well-known/agent-card.json" > /dev/null 2>&1; then
  echo "ERROR: Server failed to start within 30 seconds."
  exit 1
fi

# --- Run TCK ---

echo ""
echo "Running TCK (category: $CATEGORY)..."
echo "========================================"

TCK_ARGS="--sut-url $SUT_URL"
if [ "$CATEGORY" != "all" ]; then
  TCK_ARGS="$TCK_ARGS --category $CATEGORY"
fi

cd "$TCK_DIR"
if [ "$USE_UV" = true ]; then
  uv run ./run_tck.py $TCK_ARGS 2>&1
else
  .venv/bin/python ./run_tck.py $TCK_ARGS 2>&1
fi
cd ..

echo ""
echo "========================================"
echo "TCK run complete."
